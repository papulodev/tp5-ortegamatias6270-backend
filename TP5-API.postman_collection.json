{
  "info": {
    "name": "TP5 API - Backend",
    "description": "Colección para testear la API del TP5: Socios, Transacciones, Empleados y Publicaciones.\n\nBase URL: {{base_url}} (por defecto http://localhost:3000)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "socio_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "empleado_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "publicacion_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Socios",
      "description": "CRUD completo de Socios + filtro de activos",
      "item": [
        {
          "name": "Crear socio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('socio_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Matías\",\n  \"apellido\": \"Ortega\",\n  \"foto\": \"https://randomuser.me/api/portraits/men/1.jpg\",\n  \"dni\": \"12345678\",\n  \"numero_socio\": 1001,\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/socios",
              "host": ["{{base_url}}"],
              "path": ["api", "socios"]
            }
          }
        },
        {
          "name": "Listar todos los socios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/socios",
              "host": ["{{base_url}}"],
              "path": ["api", "socios"]
            }
          }
        },
        {
          "name": "Listar socios activos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/socios/activos",
              "host": ["{{base_url}}"],
              "path": ["api", "socios", "activos"]
            }
          }
        },
        {
          "name": "Obtener socio por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/socios/{{socio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "socios", "{{socio_id}}"]
            }
          }
        },
        {
          "name": "Modificar socio",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Matías Actualizado\",\n  \"apellido\": \"Ortega\",\n  \"activo\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/socios/{{socio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "socios", "{{socio_id}}"]
            }
          }
        },
        {
          "name": "Eliminar socio",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/socios/{{socio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "socios", "{{socio_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Transacciones",
      "description": "Log de transacciones con filtros por cliente e idiomas",
      "item": [
        {
          "name": "Crear transacción",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idioma_origen\": \"es\",\n  \"TextoOrigen\": \"Hola mundo\",\n  \"idioma_destino\": \"en\",\n  \"texto_destino\": \"Hello world\",\n  \"email_cliente\": \"cliente@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/transacciones",
              "host": ["{{base_url}}"],
              "path": ["api", "transacciones"]
            }
          }
        },
        {
          "name": "Listar todas las transacciones",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/transacciones",
              "host": ["{{base_url}}"],
              "path": ["api", "transacciones"]
            }
          }
        },
        {
          "name": "Historial por email de cliente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/transacciones/cliente/cliente@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "transacciones", "cliente", "cliente@example.com"]
            }
          }
        },
        {
          "name": "Filtrar por idiomas (origen/destino)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/transacciones/idiomas/es/en",
              "host": ["{{base_url}}"],
              "path": ["api", "transacciones", "idiomas", "es", "en"]
            }
          }
        }
      ]
    },
    {
      "name": "Empleados",
      "description": "CRUD de empleados",
      "item": [
        {
          "name": "Crear empleado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('empleado_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apellido\": \"Pérez\",\n  \"nombre\": \"Juan\",\n  \"dni\": \"87654321\",\n  \"email\": \"juan.perez@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/empleados",
              "host": ["{{base_url}}"],
              "path": ["api", "empleados"]
            }
          }
        },
        {
          "name": "Listar todos los empleados",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/empleados",
              "host": ["{{base_url}}"],
              "path": ["api", "empleados"]
            }
          }
        },
        {
          "name": "Obtener empleado por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/empleados/{{empleado_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "empleados", "{{empleado_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Publicaciones",
      "description": "CRUD de publicaciones + búsqueda combinada. Relacionadas con empleados.",
      "item": [
        {
          "name": "Crear publicación con empleado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('publicacion_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Introducción a Node.js\",\n  \"contenido\": \"Node.js es un entorno de ejecución para JavaScript...\",\n  \"imagen_asociada\": \"\",\n  \"fecha_publicacion\": \"2026-06-14\",\n  \"empleado\": {\n    \"id\": {{empleado_id}}\n  },\n  \"vigente\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/publicaciones",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Listar todas las publicaciones (con empleado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Buscar publicaciones (título + vigente)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones/buscar?titulo=Node&vigente=true",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "buscar"],
              "query": [
                { "key": "titulo", "value": "Node" },
                { "key": "vigente", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Buscar solo por título",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones/buscar?titulo=Node",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "buscar"],
              "query": [
                { "key": "titulo", "value": "Node" }
              ]
            }
          }
        },
        {
          "name": "Buscar solo por vigente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones/buscar?vigente=true",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "buscar"],
              "query": [
                { "key": "vigente", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Buscar sin parámetros (debe dar 400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones/buscar",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "buscar"]
            }
          }
        },
        {
          "name": "Modificar publicación",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Node.js Avanzado\",\n  \"vigente\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/publicaciones/{{publicacion_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "{{publicacion_id}}"]
            }
          }
        },
        {
          "name": "Eliminar publicación",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/publicaciones/{{publicacion_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "publicaciones", "{{publicacion_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      }
    }
  ]
}
